APP_ENV=local
LOG_LEVEL=INFO

TELEGRAM_BOT_TOKEN=replace-me
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4.1-mini

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/betting_bot
REDIS_URL=redis://redis:6379/0

# Comma-separated values are supported by pydantic-settings via JSON format if needed.
# DIGEST_TIMES_UTC=["09:00","12:00","15:00","18:00","20:00"]
# ENABLED_SPORTS=["football","hockey","tennis","basketball","mma"]
# ENABLED_LEAGUES=[]

MIN_ODDS=1.3
MAX_ODDS=3.5
CONFIDENCE_THRESHOLD=0.55
UPCOMING_WINDOW_HOURS=24
DEFAULT_USER_TIMEZONE=UTC
